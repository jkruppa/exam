pacman::p_load(tidyverse, readxl, plyr, stringi, magrittr)
exam_file <- file.path("/Users/jokruppa/GitHub/exam/exam_template.Rnw")
## path to lecture
lecture_path <- "/Users/jokruppa/GitHub/exam_privat/2026_SoSe/Statistik"
## copy everthing
exam_name <- str_replace(basename(lecture_path), ".*lecture/(.*)/exam", "\\1") %>%
str_replace_all("\\s", "_")
temp_exam_file <- file.path(lecture_path, str_c("Klausur_", exam_name, ".Rnw"))
file.copy(exam_file, temp_exam_file)
## remove stuff
list.files(lecture_path, full.names = TRUE, pattern = exam_name) %>%
str_subset(pattern = ".pdf", negate = TRUE) %>%
file.remove()
